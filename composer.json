{
    "name": "heroku/php-app",
    "description": "PHP application on Heroku with mbstring enabled",
    "type": "project",
    "require": {
        "php": "^8.2",
        "ext-mbstring": "*"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
